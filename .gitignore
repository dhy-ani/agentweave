# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Database ──────────────────────────────────────────────────────────────────
backend/*.db
backend/*.sqlite

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/

# ── Frontend build ────────────────────────────────────────────────────────────
frontend/build/
frontend/.env

# ── Uploads (user data, not for git) ─────────────────────────────────────────
backend/uploads/

# ── ML / binary artifacts ────────────────────────────────────────────────────
*.pt
*.pth
# data files are small (<1MB) — keep them in git so deployment works
